digraph G {
    graph [rankdir=LR, ranksep=0.7, layout=dot, clusterrank="local"];
    subgraph "cluster_G" {

        graph [style="filled,rounded", fillcolor="#80808018", label=""];
        "reflow" [label="reflow", style="filled", fillcolor="#ffffffb2", fontcolor="#000000", group="0"];
        "reflow___types" [label="reflow._types", style="filled", fillcolor="#ffffffb2", fontcolor="#000000", group="1"];
        "reflow__cache" [label="reflow.cache", style="filled", fillcolor="#ffffffb2", fontcolor="#000000", group="2"];
        "reflow__cli" [label="reflow.cli", style="filled", fillcolor="#ffffffb2", fontcolor="#000000", group="3"];
        "reflow__config" [label="reflow.config", style="filled", fillcolor="#ffffffb2", fontcolor="#000000", group="4"];
        "reflow__executors" [label="reflow.executors", style="filled", fillcolor="#ffffffb2", fontcolor="#000000", group="5"];
        "reflow__executors__local" [label="reflow.executors.local", style="filled", fillcolor="#ffffffb2", fontcolor="#000000", group="6"];
        "reflow__executors__slurm" [label="reflow.executors.slurm", style="filled", fillcolor="#ffffffb2", fontcolor="#000000", group="7"];
        "reflow__flow" [label="reflow.flow", style="filled", fillcolor="#ffffffb2", fontcolor="#000000", group="8"];
        "reflow__manifest" [label="reflow.manifest", style="filled", fillcolor="#ffffffb2", fontcolor="#000000", group="9"];
        "reflow__params" [label="reflow.params", style="filled", fillcolor="#ffffffb2", fontcolor="#000000", group="10"];
        "reflow__run" [label="reflow.run", style="filled", fillcolor="#ffffffb2", fontcolor="#000000", group="11"];
        "reflow__signals" [label="reflow.signals", style="filled", fillcolor="#ffffffb2", fontcolor="#000000", group="12"];
        "reflow__stores" [label="reflow.stores", style="filled", fillcolor="#ffffffb2", fontcolor="#000000", group="13"];
        "reflow__stores__records" [label="reflow.stores.records", style="filled", fillcolor="#ffffffb2", fontcolor="#000000", group="14"];
        "reflow__stores__sqlite" [label="reflow.stores.sqlite", style="filled", fillcolor="#ffffffb2", fontcolor="#000000", group="15"];
        "reflow__workflow" [label="reflow.workflow", style="filled", fillcolor="#ffffffb2", fontcolor="#000000", group="16"];
    }
    }
